# ===========================================================================
# Core 서버 (기존 KGPT-backend) — 실제 값은 로컬 .env 에만 입력한다.
# .env 는 .gitignore 로 추적 제외되며, 이 파일에는 실제 값/도메인/토큰을 넣지 않는다.
# ===========================================================================
PORT=3000
NODE_ENV=development

# MariaDB/MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=bloomdent_db

# Cloudinary (이미지 업로드)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Flask AI 분석 서버 URL
AI_SERVER_URL=

# ===========================================================================
# Agent Copilot 인증 (개발용 demo-token fallback)
# ===========================================================================
# production 에서 demo-token 모드가 켜진 상태를 허용하지 않도록 배포 전 점검할 것.
# 앱의 일반 로그인과는 별개이며, req.agentUser.id 만 신뢰하고 body/query/header 의
# user_id 는 신뢰하지 않는다.
AGENT_AUTH_MODE=demo-token
AGENT_DEMO_TOKEN=changeme-demo-token
AGENT_DEMO_USER_ID=1

# 이 프로젝트는 GEMINI_API_KEY만 공식적으로 사용한다. GoogleGenAI 클라이언트
# 생성 시 apiKey를 항상 명시적으로 전달해 GOOGLE_API_KEY 자동 감지를 우회하므로,
# GOOGLE_API_KEY가 환경에 설정돼 있어도 이 프로젝트에서는 무시된다.
GEMINI_API_KEY=
# Context7/공식 문서로 확인된 안정 모델(프리뷰 아님). 비어있거나 인식 불가하면
# geminiAdapter.js가 동일 값으로 fallback한다.
GEMINI_MODEL=gemini-2.5-flash
# [1000, 30000]ms로 clamp됨. 비정상 값은 15000으로 대체된다.
GEMINI_TIMEOUT_MS=15000
# 어떤 값을 넣어도 최대 3으로 clamp된다(0 이하/비정상은 기본값 3).
GEMINI_MAX_TOOL_CALLS=3

# ---------------------------------------------------------------------------
# Shopify Storefront (6A-2)
# ---------------------------------------------------------------------------
# 아래 값은 전부 "true"/"false" 문자열만 허용한다. "1"/"yes"/빈 문자열 등은
# SHOPIFY_INVALID_CONFIGURATION 으로 거부된다(값이 아예 없으면 안전하게 false).
#
# SHOPIFY_ENABLED=false 이면:
#   - 서버와 기존 API 는 정상 동작
#   - 상품 추천 API 도 정상 동작(Shopify 호출 0회)
#   - POST /api/agent/sessions/:id/shopify-cart 만 503 SHOPIFY_NOT_CONFIGURED
# 실제 Variant GID 7개가 전부 검증되기 전까지 false 를 유지할 것.
SHOPIFY_ENABLED=false

# scheme(https://)/path/query/fragment/port/userinfo 없이 hostname 만 기입한다.
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# 서버 전용 Private Storefront Token(비밀값, .env 에만).
# Shopify-Storefront-Private-Token 헤더로만 사용되며 브라우저/모바일로 전달 금지.
SHOPIFY_STOREFRONT_PRIVATE_TOKEN=

# YYYY-MM 형식만 허용. latest/unstable 금지.
SHOPIFY_STOREFRONT_API_VERSION=2026-07

# [1000, 30000] 으로 clamp.
SHOPIFY_TIMEOUT_MS=10000
# read-only Query 에만 적용되는 재시도 횟수. cartCreate Mutation 은 재시도 0회.
SHOPIFY_MAX_QUERY_RETRIES=2
# [10000, 300000] 으로 clamp. 반드시
# SHOPIFY_PENDING_LEASE_MS > SHOPIFY_TIMEOUT_MS + SHOPIFY_LEASE_SAFETY_MARGIN_MS
# 관계를 만족해야 하며, 아니면 SHOPIFY_INVALID_CONFIGURATION 으로 거부된다.
SHOPIFY_PENDING_LEASE_MS=60000
# [1000, 30000] 으로 clamp.
SHOPIFY_LEASE_SAFETY_MARGIN_MS=5000

# 실제 Variant GID 는 로컬 .env 에만 입력한다(형식: gid://shopify/ProductVariant/<숫자>).
# 값이 없거나 형식이 잘못되면 해당 상품은 Cart 에 담을 수 없고(503
# PRODUCT_VARIANT_NOT_CONFIGURED), 추천 자체는 계속 정상 동작한다.
SHOPIFY_VARIANT_GID_TOOTHBRUSH_ULTRA_SOFT=
SHOPIFY_VARIANT_GID_TOOTHBRUSH_SOFT=
SHOPIFY_VARIANT_GID_TOOTHPASTE_FLUORIDE=
SHOPIFY_VARIANT_GID_TOOTHPASTE_SENSITIVE=
SHOPIFY_VARIANT_GID_FLOSS_TAPE=
SHOPIFY_VARIANT_GID_INTERDENTAL_STARTER=
SHOPIFY_VARIANT_GID_TONGUE_CLEANER=

# opt-in 통합 테스트 이중 가드. 둘 다 true 이고 NODE_ENV !== production 이며
# SHOPIFY_STORE_DOMAIN === SHOPIFY_TEST_STORE_DOMAIN 일 때만 cartCreate 를 시도한다.
RUN_SHOPIFY_INTEGRATION_TEST=false
ALLOW_SHOPIFY_CART_MUTATION_TEST=false
SHOPIFY_TEST_STORE_DOMAIN=
