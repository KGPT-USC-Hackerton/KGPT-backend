{
  "name": "bloomdent-backend",
  "version": "1.0.0",
  "description": "BloomDent API Backend with MariaDB",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "setup-db": "node setup-database.js",
    "migrate-position": "node database/migrate-position.js",
    "deploy": "bash deploy.sh",
    "migrate:agent": "node database/run-migration.js",
    "migrate:agent:check": "node database/run-migration.js --dry-run",
    "seed:survey": "node database/run-seed.js",
    "seed:survey:check": "node database/run-seed.js --dry-run",
    "verify:migration-scratch-db": "node database/verify-migration-scratch-db.js",
    "verify:shopify-cart-scratch-db": "node database/verify-shopify-cart-scratch-db.js",
    "verify:survey-seed-scratch-db": "node database/verify-survey-seed-scratch-db.js",
    "shopify:verify-variants": "node scripts/verify-shopify-variants.js",
    "test:cavity-locations": "node utils/parseCavityLocations.test.js",
    "test:gemini-model": "node services/oralTipsService.test.js",
    "test:ai-model-insert": "node routes/aiModelAndInsert.test.js",
    "test:agent-migration": "node database/run-migration.test.js",
    "test:migration-scratch-db-guard": "node database/verify-migration-scratch-db.test.js",
    "test:survey-seed": "node database/run-seed.test.js",
    "test:agent-auth": "node middleware/agentDemoAuth.test.js",
    "test:json-parse-error": "node middleware/jsonParseErrorHandler.test.js",
    "test:no-store-cache": "node middleware/noStoreCache.test.js",
    "test:agent-sessions": "node agent/services/contextSnapshotService.test.js",
    "test:agent-cost": "node agent/tools/calculateOopCost.test.js",
    "test:gemini-adapter": "node agent/adapters/geminiAdapter.test.js",
    "test:agent-messages": "node agent/services/agentMessageService.test.js",
    "test:agent-message-controller": "node agent/controllers/messageController.test.js",
    "test:gemini-integration": "node agent/adapters/geminiAdapter.integration.test.js",
    "test:dental-pass-token": "node agent/shared/dentalPassToken.test.js",
    "test:dental-pass-public-snapshot": "node agent/shared/dentalPassPublicSnapshot.test.js",
    "test:dental-pass-service": "node agent/services/dentalPassService.test.js",
    "test:dental-pass-controller": "node agent/controllers/dentalPassController.test.js",
    "test:survey-codebook": "node agent/catalog/surveyCodebook.test.js",
    "test:product-recommendation": "node agent/services/productRecommendationService.test.js",
    "test:product-recommendation-controller": "node agent/controllers/productRecommendationController.test.js",
    "test:shopify-config": "node agent/config/shopifyConfig.test.js",
    "test:shopify-variant-mapping": "node agent/catalog/shopifyVariantMapping.test.js",
    "test:shopify-expected-skus": "node agent/catalog/shopifyExpectedSkus.test.js",
    "test:shopify-request-hash": "node agent/shared/shopifyRequestHash.test.js",
    "test:shopify-safe-error": "node agent/shared/shopifySafeErrorDetails.test.js",
    "test:shopify-adapter": "node agent/adapters/shopifyStorefrontAdapter.test.js",
    "test:shopify-cart-service": "node agent/services/shopifyCartService.test.js",
    "test:shopify-cart-controller": "node agent/controllers/shopifyCartController.test.js"
  },
  "keywords": [
    "express",
    "mariadb",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@google/genai": "^1.30.0",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "mysql2": "^3.6.5",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
